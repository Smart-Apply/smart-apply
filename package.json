{
  "name": "smart-apply",
  "version": "3.0.0",
  "description": "Smart Apply MVP - AI-powered job application assistant (Monorepo)",
  "author": "Smart Apply Team",
  "private": true,
  "license": "BUSL-1.1",
  "packageManager": "npm@10.1.0",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "api:dev": "npm run start:dev --workspace=apps/api",
    "api:build": "npm run build --workspace=apps/api",
    "api:test": "npm run test:e2e --workspace=apps/api",
    "web:dev": "npm run dev --workspace=apps/web",
    "web:build": "npm run build --workspace=apps/web",
    "web:lint": "npm run lint --workspace=apps/web",
    "shared:build": "npm run build --workspace=packages/shared",
    "shared:watch": "npm run watch --workspace=packages/shared",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@smart-apply/api",
    "build:web": "turbo run build --filter=@smart-apply/web",
    "build:changed": "turbo run build --filter=[HEAD^1]",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "typecheck": "turbo run typecheck",
    "build:legacy": "npm run shared:build && npm run api:build && npm run web:build",
    "test:unit:watch": "npm run test:unit:watch --workspace=apps/api",
    "test:unit:cov": "npm run test:unit:cov --workspace=apps/api",
    "test:integration": "npm run test:integration --workspace=apps/api",
    "test:integration:watch": "npm run test:integration:watch --workspace=apps/api",
    "test:integration:cov": "npm run test:integration:cov --workspace=apps/api",
    "test:e2e": "npm run test:e2e --workspace=apps/api",
    "test:all": "npm run test:all --workspace=apps/api",
    "test:all:cov": "npm run test:all:cov --workspace=apps/api",
    "test:cov": "npm run test:cov --workspace=apps/api",
    "prisma:generate": "cd apps/api && npm run prisma:generate",
    "prisma:migrate": "cd apps/api && npm run prisma:migrate",
    "prisma:seed": "cd apps/api && npm run prisma:seed",
    "prisma:seed:templates": "cd apps/api && npm run prisma:seed:templates",
    "prisma:studio": "cd apps/api && npm run prisma:studio"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/common": "^11.1.12",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^11.1.12",
    "@nestjs/throttler": "^6.5.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.25",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "baseline-browser-mapping": "^2.9.4",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "prisma": "5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "postcss": "^8.5.10",
    "fast-xml-builder": ">=1.1.7 <1.2.0",
    "@nestjs/schematics": {
      "@angular-devkit/core": {
        "ajv": "^8.18.0",
        "picomatch": "^4.0.4"
      }
    }
  },
  "engines": {
    "node": ">=20.19.0 || >=24.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@nestjs/event-emitter": "^3.0.1"
  }
}
