{
  "name": "smart-apply",
  "version": "3.0.4",
  "description": "Smart Apply MVP - AI-powered job application assistant (Monorepo)",
  "author": "Smart Apply Team",
  "private": true,
  "license": "BUSL-1.1",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "api:dev": "pnpm --filter @smart-apply/api start:dev",
    "api:build": "pnpm --filter @smart-apply/api build",
    "api:test": "pnpm --filter @smart-apply/api test:e2e",
    "web:dev": "pnpm --filter @smart-apply/web dev",
    "web:build": "pnpm --filter @smart-apply/web build",
    "web:lint": "pnpm --filter @smart-apply/web lint",
    "shared:build": "pnpm --filter @smart-apply/shared build",
    "shared:watch": "pnpm --filter @smart-apply/shared watch",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@smart-apply/api",
    "build:web": "turbo run build --filter=@smart-apply/web",
    "build:changed": "turbo run build --filter=[HEAD^1]",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "typecheck": "turbo run typecheck",
    "build:legacy": "pnpm shared:build && pnpm api:build && pnpm web:build",
    "test:unit:watch": "pnpm --filter @smart-apply/api test:unit:watch",
    "test:unit:cov": "pnpm --filter @smart-apply/api test:unit:cov",
    "test:integration": "pnpm --filter @smart-apply/api test:integration",
    "test:integration:watch": "pnpm --filter @smart-apply/api test:integration:watch",
    "test:integration:cov": "pnpm --filter @smart-apply/api test:integration:cov",
    "test:e2e": "pnpm --filter @smart-apply/api test:e2e",
    "test:all": "pnpm --filter @smart-apply/api test:all",
    "test:all:cov": "pnpm --filter @smart-apply/api test:all:cov",
    "test:cov": "pnpm --filter @smart-apply/api test:cov",
    "prisma:generate": "pnpm --filter @smart-apply/api prisma:generate",
    "prisma:migrate": "pnpm --filter @smart-apply/api prisma:migrate",
    "prisma:seed": "pnpm --filter @smart-apply/api prisma:seed",
    "prisma:seed:templates": "pnpm --filter @smart-apply/api prisma:seed:templates",
    "prisma:studio": "pnpm --filter @smart-apply/api prisma:studio"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/common": "^11.1.12",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^11.1.12",
    "@nestjs/throttler": "^6.5.0",
    "@swc/core": "^1.10.1",
    "@types/node": "^20.19.25",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "baseline-browser-mapping": "^2.10.30",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.2",
    "prettier": "^3.1.1",
    "prisma": "5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.8.1",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.1",
    "vite": "^8.0.13",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "postcss": "^8.5.10",
    "fast-xml-builder": ">=1.1.7 <1.2.0"
  },
  "engines": {
    "node": ">=20.19.0 || >=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "dependencies": {
    "@nestjs/event-emitter": "^3.0.1"
  }
}
