{
  "$schema": "https://swc.rs/schema.json",
  "sourceMaps": "inline",
  "module": {
    "type": "es6"
  },
  "jsc": {
    "target": "es2021",
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true,
      "react": {
        "runtime": "automatic"
      }
    },
    "keepClassNames": true
  }
}
