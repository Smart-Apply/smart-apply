# Test Environment Variables
# DO NOT use these in production!

# Database
DATABASE_URL=postgresql://postgres:testpass@localhost:5433/smartapply_test

# Security - JWT
JWT_SECRET=TEST_SECRET_DO_NOT_USE_IN_PRODUCTION_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# Security - CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Security - Rate Limiting
RATE_LIMIT_TTL=900
RATE_LIMIT_MAX=10000
RATE_LIMIT_AUTH_TTL=900
RATE_LIMIT_AUTH_MAX=100

# Security - CSRF (disabled for tests)
ENABLE_CSRF=false

# Compression (enabled for tests)
ENABLE_COMPRESSION=true

# Storage
STORAGE_DRIVER=disk

# Jobs/Queue
JOBS_PROVIDER=in-memory

# LLM Provider (use mock for fast tests)
LLM_PROVIDER=mock

# PDF Generation
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# File Upload
MAX_FILE_SIZE_MB=10
MAX_PROFILE_PHOTO_SIZE_MB=5

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Circuit Breaker - LLM Service Protection
LLM_CIRCUIT_BREAKER_TIMEOUT=60000
LLM_CIRCUIT_BREAKER_ERROR_THRESHOLD=50
LLM_CIRCUIT_BREAKER_RESET_TIMEOUT=30000
LLM_CIRCUIT_BREAKER_ROLLING_COUNT_TIMEOUT=10000
LLM_CIRCUIT_BREAKER_ROLLING_COUNT_BUCKETS=10

# Global Request Timeout
REQUEST_TIMEOUT_MS=30000

# Node Environment
NODE_ENV=test
