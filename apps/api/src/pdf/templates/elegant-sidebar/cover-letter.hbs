<!DOCTYPE html>
<html lang="{{language}}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{{candidateName}} - Cover Letter</title>
</head>
<body>
<div class="cover-letter-container">
    <!-- Header -->
    <header class="cover-letter-header">
        <h1 class="cover-letter-name">{{candidateName}}</h1>
        {{#if targetJobTitle}}
        <p class="cover-letter-job-title">{{targetJobTitle}}</p>
        {{/if}}
        <div class="cover-letter-contact">
            {{#if fullAddress}}
            <span class="cover-letter-contact-item">
                <svg class="cover-letter-contact-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                </svg>
                {{fullAddress}}
            </span>
            {{/if}}
            {{#if email}}
            <span class="cover-letter-contact-item">
                <svg class="cover-letter-contact-icon" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                </svg>
                {{email}}
            </span>
            {{/if}}
            {{#if phone}}
            <span class="cover-letter-contact-item">
                <svg class="cover-letter-contact-icon" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                {{phone}}
            </span>
            {{/if}}
            {{#if linkedin}}
            <span class="cover-letter-contact-item">
                <svg class="cover-letter-contact-icon" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
            </span>
            {{/if}}
        </div>
    </header>

    <!-- Date -->
    <div class="cover-letter-date">
        {{date}}
    </div>

    <!-- Body -->
    <div class="cover-letter-body">
        {{{content}}}
    </div>

    <!-- Closing -->
    <div class="cover-letter-closing">
        <p>{{closingPhrase}}</p>
        <p class="cover-letter-signature">{{candidateName}}</p>
    </div>
</div>
</body>
</html>
