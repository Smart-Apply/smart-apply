<!DOCTYPE html>
<html lang="{{language}}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{{candidateName}} - Resume</title>
</head>
<body>
<div class="cv-container">
    <!-- Header Section -->
    <header class="cv-header">
        <div class="profile-header">
            <div>
                <h1 class="profile-name">{{candidateName}}</h1>
                {{#if targetJobTitle}}
                <p class="target-job-title">{{targetJobTitle}}</p>
                {{/if}}
            </div>
        </div>
    </header>

    <!-- Content Area -->
    <div class="cv-content">
        <!-- Sidebar -->
        <aside class="cv-sidebar">
            <!-- Contact Information -->
            <div class="sidebar-section">
                <h2 class="sidebar-section-title">{{t "contact" language}}</h2>
                <ul class="contact-info-list">
                    {{#if fullAddress}}
                    <li class="contact-info-item">
                        <svg class="contact-info-icon" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                        </svg>
                        {{fullAddress}}
                    </li>
                    {{/if}}
                    {{#if email}}
                    <li class="contact-info-item">
                        <svg class="contact-info-icon" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
                            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
                        </svg>
                        {{email}}
                    </li>
                    {{/if}}
                    {{#if phone}}
                    <li class="contact-info-item">
                        <svg class="contact-info-icon" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                        </svg>
                        {{phone}}
                    </li>
                    {{/if}}
                    {{#if website}}
                    <li class="contact-info-item">
                        <svg class="contact-info-icon" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4.083 9h1.946c.089-1.546.383-2.97.837-4.118A6.004 6.004 0 004.083 9zM10 2a8 8 0 100 16 8 8 0 000-16zm0 2c-.076 0-.232.032-.465.262-.238.234-.497.623-.737 1.182-.389.907-.673 2.142-.766 3.556h3.936c-.093-1.414-.377-2.649-.766-3.556-.24-.559-.499-.948-.737-1.182C10.232 4.032 10.076 4 10 4zm3.971 5c-.089-1.546-.383-2.97-.837-4.118A6.004 6.004 0 0115.917 9h-1.946zm-2.003 2H8.032c.093 1.414.377 2.649.766 3.556.24.559.499.948.737 1.182.233.23.389.262.465.262.076 0 .232-.032.465-.262.238-.234.497-.623.737-1.182.389-.907.673-2.142.766-3.556zm1.166 4.118c.454-1.147.748-2.572.837-4.118h1.946a6.004 6.004 0 01-2.783 4.118zm-6.268 0C6.412 13.97 6.118 12.546 6.03 11H4.083a6.004 6.004 0 002.783 4.118z" clip-rule="evenodd"></path>
                        </svg>
                        <a href="{{website}}" target="_blank" class="contact-link">{{website}}</a>
                    </li>
                    {{/if}}
                    {{#if linkedin}}
                    <li class="contact-info-item">
                        <svg class="contact-info-icon" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                        <a href="{{linkedin}}" target="_blank" class="contact-link">LinkedIn</a>
                    </li>
                    {{/if}}
                    {{#if github}}
                    <li class="contact-info-item">
                        <svg class="contact-info-icon" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                        </svg>
                        <a href="{{github}}" target="_blank" class="contact-link">GitHub</a>
                    </li>
                    {{/if}}
                </ul>
            </div>

            <!-- Education -->
            {{#if education}}
            <div class="sidebar-section">
                <h2 class="sidebar-section-title">{{t "resume.education" language}}</h2>
                <ul class="education-sidebar-list">
                    {{#each education}}
                    <li class="education-sidebar-item">
                        <div class="education-degree">
                            {{this.degree}}{{#if this.fieldOfStudy}} {{this.fieldOfStudy}}{{/if}}
                        </div>
                        <div class="education-institution">{{this.institution}}</div>
                        <div class="education-period">{{this.year}}</div>
                    </li>
                    {{/each}}
                </ul>
            </div>
            {{/if}}

            <!-- Skills -->
            {{#if skillCategories}}
            <div class="sidebar-section">
                <h2 class="sidebar-section-title">{{t "resume.skills" language}}</h2>
                {{#each skillCategories}}
                <div class="skill-category">
                    {{#if this.type}}
                    <p class="skill-category-title">{{this.type}}</p>
                    {{/if}}
                    <ul class="skills-list">
                        {{#each this.skills}}
                        <li class="skill-item">{{this}}</li>
                        {{/each}}
                    </ul>
                </div>
                {{/each}}
            </div>
            {{/if}}

            <!-- Languages -->
            {{#if languages}}
            <div class="sidebar-section">
                <h2 class="sidebar-section-title">{{t "resume.languages" language}}</h2>
                <ul class="languages-list">
                    {{#each languages}}
                    <li class="language-item">
                        <span class="language-name">{{translateLang this.name @root.language}}</span>
                        {{#if this.level}}<span class="language-level">{{t this.level @root.language}}</span>{{/if}}
                    </li>
                    {{/each}}
                </ul>
            </div>
            {{/if}}
        </aside>

        <!-- Main Content -->
        <main class="cv-main">
            <!-- Professional Summary -->
            {{#if summary}}
            <section class="main-section">
                <h2 class="main-section-title">{{t "resume.summary" language}}</h2>
                <p class="professional-summary">{{nl2br summary}}</p>
            </section>
            {{/if}}

            <!-- Work Experience -->
            {{#if experiences}}
            <section class="main-section">
                <h2 class="main-section-title">{{t "resume.experience" language}}</h2>
                <ul class="experience-list">
                    {{#each experiences}}
                    <li class="experience-item">
                        <div class="item-header">
                            <h3 class="item-title">{{this.title}}</h3>
                            <span class="item-period">{{this.dateRange}}</span>
                        </div>
                        <div class="item-company">{{this.company}}{{#if this.location}} · {{this.location}}{{/if}}</div>
                        {{#if this.description}}
                        <div class="item-description">{{{this.description}}}</div>
                        {{/if}}
                        {{#if this.achievements}}
                        <ul class="achievements-list">
                            {{#each this.achievements}}
                            <li class="achievement-item">{{this}}</li>
                            {{/each}}
                        </ul>
                        {{/if}}
                    </li>
                    {{/each}}
                </ul>
            </section>
            {{/if}}

            <!-- Projects -->
            {{#if projects}}
            <section class="main-section">
                <h2 class="main-section-title">{{t "resume.projects" language}}</h2>
                <ul class="experience-list">
                    {{#each projects}}
                    <li class="project-item">
                        <div class="item-header">
                            <h3 class="item-title">{{this.name}}</h3>
                            {{#if this.url}}
                            <a href="{{this.url}}" target="_blank" class="contact-link">{{this.url}}</a>
                            {{/if}}
                        </div>
                        {{#if this.description}}
                        <div class="item-description">{{{this.description}}}</div>
                        {{/if}}
                        {{#if this.technologies}}
                        <p class="item-description"><strong>Technologies:</strong> {{this.technologies}}</p>
                        {{/if}}
                    </li>
                    {{/each}}
                </ul>
            </section>
            {{/if}}

            <!-- Certifications -->
            {{#if certifications}}
            <section class="main-section">
                <h2 class="main-section-title">{{t "resume.certifications" language}}</h2>
                <ul class="courses-list">
                    {{#each certifications}}
                    <li class="course-item">
                        <div class="item-header">
                            <h3 class="item-title">{{this.name}}</h3>
                            {{#if this.date}}
                            <span class="item-period">{{this.date}}</span>
                            {{/if}}
                        </div>
                        {{#if this.issuer}}
                        <p class="item-institution">{{this.issuer}}</p>
                        {{/if}}
                    </li>
                    {{/each}}
                </ul>
            </section>
            {{/if}}
        </main>
    </div>
</div>
</body>
</html>
