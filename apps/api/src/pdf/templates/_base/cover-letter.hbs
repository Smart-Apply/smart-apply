<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cover Letter - {{candidateName}}</title>
</head>
<body>
  {{! Header - Contact Information }}
  <div class="header no-break">
    <h1>{{candidateName}}</h1>
    {{#if targetJobTitle}}
    <p class="job-title">{{targetJobTitle}}</p>
    {{/if}}
    <div class="contact-info">
      {{#if fullAddress}}
        {{fullAddress}}
      {{/if}}
      {{#if email}}
        <span class="separator">|</span>
        {{email}}
      {{/if}}
      {{#if phone}}
        <span class="separator">|</span>
        {{phone}}
      {{/if}}
      {{#if linkedin}}
        <span class="separator">|</span>
        {{linkedin}}
      {{/if}}
      {{#if github}}
        <span class="separator">|</span>
        {{github}}
      {{/if}}
    </div>
  </div>

  {{! Date }}
  <div class="date-section">
    {{date}}
  </div>

  {{! Body Content - includes salutation, body, and closing from LLM }}
  <div class="body-content">
    {{{content}}}
  </div>

  {{! Signature }}
  <div class="signature no-break">
    <p><strong>{{candidateName}}</strong></p>
  </div>

  {{#if footer}}
  <div class="footer">
    {{{footer}}}
  </div>
  {{/if}}
</body>
</html>
