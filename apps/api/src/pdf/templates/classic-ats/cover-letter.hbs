<!DOCTYPE html>
<html lang="{{language}}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{{candidateName}} - Cover Letter</title>
</head>
<body>
<div class="cover-letter">
    {{! ========================================
        HEADER - Centered Name & Contact Info
        ======================================== }}
    <header class="cover-letter-header">
        <h1 class="candidate-name">{{candidateName}}</h1>
        {{#if targetJobTitle}}
        <p class="job-title">{{targetJobTitle}}</p>
        {{/if}}
        
        <div class="contact-info">
            {{#if fullAddress}}
            <span>{{fullAddress}}</span>
            {{/if}}
            {{#if fullAddress}}{{#if phone}}<span class="separator">|</span>{{/if}}{{/if}}
            {{#if phone}}
            <span>{{phone}}</span>
            {{/if}}
            {{#if phone}}{{#if email}}<span class="separator">|</span>{{/if}}{{/if}}
            {{#if email}}
            <a href="mailto:{{email}}">{{email}}</a>
            {{/if}}
            {{#if email}}{{#if linkedin}}<span class="separator">|</span>{{/if}}{{/if}}
            {{#if linkedin}}
            <a href="{{linkedin}}" target="_blank">LinkedIn</a>
            {{/if}}
        </div>
    </header>

    {{! ========================================
        DATE
        ======================================== }}
    {{#if date}}
    <div class="cover-letter-date">
        {{date}}
    </div>
    {{/if}}

    {{! ========================================
        LETTER BODY
        The LLM-generated content already includes salutation
        (e.g., "Sehr geehrtes Team," or "Dear Hiring Manager,")
        ======================================== }}
    <div class="cover-letter-body">
        {{{content}}}
    </div>

    {{! ========================================
        CLOSING
        ======================================== }}
    <div class="cover-letter-closing">
        {{#if closingPhrase}}
        <p>{{closingPhrase}}</p>
        {{/if}}
        <p class="cover-letter-signature">{{candidateName}}</p>
    </div>
</div>
</body>
</html>
