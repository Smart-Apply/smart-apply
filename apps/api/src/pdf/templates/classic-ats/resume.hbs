<!DOCTYPE html>
<html lang="{{language}}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{{candidateName}} - Resume</title>
</head>
<body>
<div class="resume">
    {{! ========================================
        HEADER - Centered Name & Contact Info
        ======================================== }}
    <header class="resume-header">
        <h1 class="candidate-name">{{candidateName}}</h1>
        {{#if targetJobTitle}}
        <p class="job-title">{{targetJobTitle}}</p>
        {{/if}}
        
        <div class="contact-info">
            {{#if phone}}
            <span>{{phone}}</span>
            {{/if}}
            {{#if phone}}{{#if email}}<span class="separator">|</span>{{/if}}{{/if}}
            {{#if email}}
            <a href="mailto:{{email}}">{{email}}</a>
            {{/if}}
            {{#if email}}{{#if linkedin}}<span class="separator">|</span>{{/if}}{{/if}}
            {{#if linkedin}}
            <a href="{{linkedin}}" target="_blank">LinkedIn</a>
            {{/if}}
            {{#if linkedin}}{{#if github}}<span class="separator">|</span>{{/if}}{{/if}}
            {{#if github}}
            <a href="{{github}}" target="_blank">GitHub</a>
            {{/if}}
            {{#if github}}{{#if website}}<span class="separator">|</span>{{/if}}{{/if}}
            {{#if website}}
            <a href="{{website}}" target="_blank">{{website}}</a>
            {{/if}}
            {{#if location}}
            <span class="separator">|</span>
            <span>{{location}}</span>
            {{/if}}
        </div>
    </header>

    {{! ========================================
        SUMMARY
        ======================================== }}
    {{#if summary}}
    <section class="resume-section">
        <h2 class="section-title">{{t "resume.summary" language}}</h2>
        <p class="summary-text">{{{summary}}}</p>
    </section>
    {{/if}}

    {{! ========================================
        EDUCATION - Placed before Experience (LaTeX style)
        ======================================== }}
    {{#if education}}
    <section class="resume-section">
        <h2 class="section-title">{{t "resume.education" language}}</h2>
        {{#each education}}
        <div class="education-item">
            <div class="item-header">
                <span class="item-title">{{this.institution}}</span>
                <span class="item-date">{{this.year}}</span>
            </div>
            <div class="item-subtitle">
                <span class="item-institution">{{this.degree}}{{#if this.fieldOfStudy}}, {{this.fieldOfStudy}}{{/if}}</span>
                {{#if this.location}}
                <span class="item-location">{{this.location}}</span>
                {{/if}}
            </div>
            {{#if this.gpa}}
            <p class="item-description">GPA: {{this.gpa}}</p>
            {{/if}}
            {{#if this.description}}
            <p class="item-description">{{{this.description}}}</p>
            {{/if}}
        </div>
        {{/each}}
    </section>
    {{/if}}

    {{! ========================================
        EXPERIENCE
        ======================================== }}
    {{#if experiences}}
    <section class="resume-section">
        <h2 class="section-title">{{t "resume.experience" language}}</h2>
        {{#each experiences}}
        <div class="experience-item">
            <div class="item-header">
                <span class="item-title">{{this.title}}</span>
                <span class="item-date">{{this.dateRange}}</span>
            </div>
            <div class="item-subtitle">
                <span class="item-company">{{this.company}}</span>
                {{#if this.location}}
                <span class="item-location">{{this.location}}</span>
                {{/if}}
            </div>
            {{#if this.description}}
            <p class="item-description">{{{this.description}}}</p>
            {{/if}}
            {{#if this.achievements}}
            <ul class="achievements-list">
                {{#each this.achievements}}
                <li>{{{this}}}</li>
                {{/each}}
            </ul>
            {{/if}}
        </div>
        {{/each}}
    </section>
    {{/if}}

    {{! ========================================
        PROJECTS
        ======================================== }}
    {{#if projects}}
    <section class="resume-section">
        <h2 class="section-title">{{t "resume.projects" language}}</h2>
        {{#each projects}}
        <div class="project-item">
            <div class="project-title-row">
                <span class="project-name">{{this.name}}</span>
                {{#if this.technologies}}
                <span class="project-tech">{{this.technologies}}</span>
                {{/if}}
            </div>
            {{#if this.date}}
            <div class="item-subtitle">
                <span class="item-date">{{this.date}}</span>
            </div>
            {{/if}}
            {{#if this.description}}
            <p class="item-description">{{{this.description}}}</p>
            {{/if}}
            {{#if this.highlights}}
            <ul class="achievements-list">
                {{#each this.highlights}}
                <li>{{{this}}}</li>
                {{/each}}
            </ul>
            {{/if}}
        </div>
        {{/each}}
    </section>
    {{/if}}

    {{! ========================================
        TECHNICAL SKILLS - Inline Format
        ======================================== }}
    {{#if skillCategories}}
    <section class="resume-section">
        <h2 class="section-title">{{t "resume.skills" language}}</h2>
        <div class="skills-container">
            {{#each skillCategories}}
            <div class="skill-row">
                {{#if this.type}}
                <span class="skill-category-label">{{this.type}}:</span>
                {{/if}}
                <span class="skill-list">{{#each this.skills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</span>
            </div>
            {{/each}}
        </div>
    </section>
    {{/if}}

    {{! ========================================
        CERTIFICATIONS
        ======================================== }}
    {{#if certifications}}
    <section class="resume-section">
        <h2 class="section-title">{{t "resume.certifications" language}}</h2>
        {{#each certifications}}
        <div class="certification-item">
            <div class="certification-row">
                <span class="certification-name">{{this.name}}</span>
                {{#if this.date}}
                <span class="certification-date">{{this.date}}</span>
                {{/if}}
            </div>
            {{#if this.issuer}}
            <span class="certification-issuer">{{this.issuer}}</span>
            {{/if}}
        </div>
        {{/each}}
    </section>
    {{/if}}

    {{! ========================================
        LANGUAGES
        ======================================== }}
    {{#if languages}}
    <section class="resume-section">
        <h2 class="section-title">{{t "resume.languages" language}}</h2>
        <div class="languages-list">
            {{#each languages}}
            <span class="language-item">
                {{translateLang this.name @root.language}}{{#if this.level}} <span class="language-level">({{t this.level @root.language}})</span>{{/if}}
            </span>
            {{/each}}
        </div>
    </section>
    {{/if}}
</div>
</body>
</html>
