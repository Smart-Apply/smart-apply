<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cover Letter - {{candidateName}}</title>
</head>
<body>
  {{! Header - Contact Information }}
  <div class="header no-break">
    <h1>{{candidateName}}</h1>
    <div class="contact-info">
      {{#if email}}
        {{email}}
      {{/if}}
      {{#if phone}}
        <span class="separator">|</span>
        {{phone}}
      {{/if}}
      {{#if location}}
        <span class="separator">|</span>
        {{location}}
      {{/if}}
      {{#if linkedin}}
        <span class="separator">|</span>
        {{linkedin}}
      {{/if}}
      {{#if github}}
        <span class="separator">|</span>
        {{github}}
      {{/if}}
    </div>
  </div>

  {{! Date }}
  <div class="date-section">
    {{date}}
  </div>

  {{! Recipient }}
  {{#if recipientName}}
  <div class="recipient-section no-break">
    <p><strong>{{recipientName}}</strong></p>
    {{#if companyName}}
    <p>{{companyName}}</p>
    {{/if}}
    {{#if companyAddress}}
    <p>{{companyAddress}}</p>
    {{/if}}
  </div>
  {{/if}}

  {{! Salutation }}
  <div class="salutation">
    <p>Dear {{#if recipientName}}{{recipientName}}{{else}}Hiring Manager{{/if}},</p>
  </div>

  {{! Body Content }}
  <div class="body-content">
    {{{content}}}
  </div>

  {{! Closing }}
  <div class="closing no-break">
    <p>{{closingPhrase}}</p>
    <div class="signature">
      <p><strong>{{candidateName}}</strong></p>
    </div>
  </div>

  {{#if footer}}
  {{! Optional Footer }}
  <div class="footer">
    {{{footer}}}
  </div>
  {{/if}}
</body>
</html>
