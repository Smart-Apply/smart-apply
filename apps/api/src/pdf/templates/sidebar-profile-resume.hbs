<!DOCTYPE html>
<html lang="{{language}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{candidateName}} - {{t 'resume.title'}}</title>
</head>
<body>
  <div class="resume-wrapper">
    <!-- Left Sidebar -->
    <aside class="sidebar">
      <!-- Profile Photo -->
      {{#if profilePhotoUrl}}
      <div class="profile-photo">
        <img src="{{profilePhotoUrl}}" alt="{{candidateName}}">
      </div>
      {{/if}}

      <!-- Contact Section -->
      <section class="sidebar-section contact">
        <h2 class="sidebar-heading">{{t 'resume.contact'}}</h2>
        
        {{#if phone}}
        <div class="contact-item">
          <h3>{{t 'resume.phone'}}</h3>
          <p>{{phone}}</p>
        </div>
        {{/if}}

        {{#if email}}
        <div class="contact-item">
          <h3>{{t 'resume.email'}}</h3>
          <p>{{email}}</p>
        </div>
        {{/if}}

        {{#if location}}
        <div class="contact-item">
          <h3>{{t 'resume.address'}}</h3>
          <p>{{location}}</p>
        </div>
        {{/if}}
      </section>

      <!-- Education Section -->
      {{#if education}}
      <section class="sidebar-section education">
        <h2 class="sidebar-heading">{{t 'resume.education'}}</h2>
        {{#each education}}
        <div class="education-item">
          <p class="date-range">
            {{#if this.startDate}}{{formatDate this.startDate @root.language}}{{/if}}
            {{#if this.endDate}} - {{formatDate this.endDate @root.language}}{{else}}{{#if this.startDate}} - {{t 'resume.present'}}{{/if}}{{/if}}
          </p>
          <h3>{{this.degree}}</h3>
          <p class="institution">{{this.institution}}</p>
        </div>
        {{/each}}
      </section>
      {{/if}}

      <!-- Expertise/Skills Section -->
      {{#if skillCategories}}
      <section class="sidebar-section expertise">
        <h2 class="sidebar-heading">{{t 'resume.expertise'}}</h2>
        <ul class="expertise-list">
          {{#each skillCategories}}
            {{#each this.skills}}
            <li>{{this}}</li>
            {{/each}}
          {{/each}}
        </ul>
      </section>
      {{/if}}

      <!-- Languages Section -->
      {{#if languages}}
      <section class="sidebar-section languages">
        <h2 class="sidebar-heading">{{t 'resume.languages'}}</h2>
        {{#each languages}}
        <div class="language-item">
          <p class="language-name">{{this.name}}</p>
          {{#if this.proficiency}}
          <p class="proficiency">{{this.proficiency}}</p>
          {{/if}}
        </div>
        {{/each}}
      </section>
      {{/if}}

      <!-- Certificates Section -->
      {{#if certificates}}
      <section class="sidebar-section certificates">
        <h2 class="sidebar-heading">{{t 'resume.certificates'}}</h2>
        {{#each certificates}}
        <div class="certificate-item">
          <h3>{{this.name}}</h3>
          {{#if this.issuer}}
          <p class="issuer">{{this.issuer}}</p>
          {{/if}}
          {{#if this.date}}
          <p class="cert-date">{{this.date}}</p>
          {{/if}}
        </div>
        {{/each}}
      </section>
      {{/if}}
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      <header class="header">
        <h1 class="name">{{candidateName}}</h1>
        <p class="title">{{jobTitle}}</p>
        {{#if summary}}
        <div class="summary">{{{summary}}}</div>
        {{/if}}
      </header>

      <!-- Experience Section -->
      {{#if experiences}}
      <section class="main-section experience">
        <h2 class="section-heading">{{t 'resume.experience'}}</h2>
        {{#each experiences}}
        <div class="experience-item">
          <div class="timeline-marker"></div>
          <div class="experience-content">
            <p class="date-range">
              {{formatDate this.startDate @root.language}}
              {{#if this.isCurrent}}
                - {{t 'resume.present'}}
              {{else}}
                {{#if this.endDate}} - {{formatDate this.endDate @root.language}}{{/if}}
              {{/if}}
            </p>
            <p class="company-location">{{this.company}}{{#if this.location}} | {{this.location}}{{/if}}</p>
            <h3 class="position-title">{{this.title}}</h3>
            {{#if this.description}}
            <div class="description">{{{this.description}}}</div>
            {{/if}}
            {{#if this.achievements}}
            <ul class="achievements">
              {{#each this.achievements}}
              <li>{{this}}</li>
              {{/each}}
            </ul>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </section>
      {{/if}}

      <!-- Projects Section (if any) -->
      {{#if projects}}
      <section class="main-section projects">
        <h2 class="section-heading">{{t 'resume.projects'}}</h2>
        {{#each projects}}
        <div class="project-item">
          <h3>{{this.name}}</h3>
          <p class="description">{{this.description}}</p>
          {{#if this.technologies}}
          <p class="technologies"><strong>{{t 'resume.technologies'}}:</strong> {{this.technologies}}</p>
          {{/if}}
        </div>
        {{/each}}
      </section>
      {{/if}}

      <!-- References Section -->
      {{#if references}}
      <section class="main-section references">
        <h2 class="section-heading">{{t 'resume.references'}}</h2>
        <div class="references-grid">
          {{#each references}}
          <div class="reference-item">
            <h3>{{this.name}}</h3>
            <p class="reference-title">{{this.position}}</p>
            <p class="reference-contact">
              {{#if this.phone}}<strong>{{t 'resume.phone'}}:</strong> {{this.phone}}<br>{{/if}}
              {{#if this.email}}<strong>{{t 'resume.email'}}:</strong> {{this.email}}{{/if}}
            </p>
          </div>
          {{/each}}
        </div>
      </section>
      {{/if}}
    </main>
  </div>
</body>
</html>
