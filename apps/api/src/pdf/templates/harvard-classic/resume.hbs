<!DOCTYPE html>
<html lang="{{language}}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{{candidateName}} - Resume</title>
</head>
<body>
<div class="resume">
    {{! =========== HEADER =========== }}
    <header class="resume-header">
        <h1 class="candidate-name">{{candidateName}}</h1>
        <hr class="header-divider"/>
    </header>

    {{! =========== CONTACT INFO =========== }}
    <div class="contact-info">
        {{#if fullAddress}}<span>{{fullAddress}}</span>{{/if}}
        {{#if fullAddress}}{{#if email}}<span class="contact-separator">•</span>{{/if}}{{/if}}
        {{#if email}}<span><a href="mailto:{{email}}">{{email}}</a></span>{{/if}}
        {{#if email}}{{#if phone}}<span class="contact-separator">•</span>{{/if}}{{/if}}
        {{#if phone}}<span>{{phone}}</span>{{/if}}
        {{#if phone}}{{#if linkedin}}<span class="contact-separator">•</span>{{/if}}{{/if}}
        {{#if linkedin}}<span><a href="{{linkedin}}" target="_blank">LinkedIn</a></span>{{/if}}
        {{#if linkedin}}{{#if github}}<span class="contact-separator">•</span>{{/if}}{{/if}}
        {{#if github}}<span><a href="{{github}}" target="_blank">GitHub</a></span>{{/if}}
    </div>

    {{! =========== SUMMARY =========== }}
    {{#if summary}}
    <section>
        <h2 class="section-header">{{t "resume.summary" language}}</h2>
        <p class="summary-text">{{{summary}}}</p>
    </section>
    {{/if}}

    {{! =========== EDUCATION =========== }}
    {{#if education}}
    <section>
        <h2 class="section-header">{{t "resume.education" language}}</h2>
        {{#each education}}
        <div class="entry education-entry">
            <div class="item-row">
                <div class="item-left">
                    <span class="institution-name">{{this.institution}}</span>
                </div>
                <div class="item-right">
                    <span class="location">{{this.location}}</span>
                </div>
            </div>
            <div class="item-row">
                <div class="item-left">
                    <span class="degree-title">{{this.degree}}{{#if this.fieldOfStudy}}, {{this.fieldOfStudy}}{{/if}}{{#if this.gpa}}. GPA: {{this.gpa}}{{/if}}</span>
                </div>
                <div class="item-right">
                    <span class="date">{{this.year}}</span>
                </div>
            </div>
            {{#if this.description}}
            <div class="description">{{{this.description}}}</div>
            {{/if}}
            {{#if this.achievements}}
            <ul class="item-bullets">
                {{#each this.achievements}}
                <li>{{{this}}}</li>
                {{/each}}
            </ul>
            {{/if}}
        </div>
        {{/each}}
    </section>
    {{/if}}

    {{! =========== EXPERIENCE =========== }}
    {{#if experiences}}
    <section>
        <h2 class="section-header">{{t "resume.experience" language}}</h2>
        {{#each experiences}}
        <div class="entry experience-entry">
            <div class="item-row">
                <div class="item-left">
                    <span class="organization-name">{{this.company}}</span>
                </div>
                <div class="item-right">
                    <span class="location">{{this.location}}</span>
                </div>
            </div>
            <div class="item-row">
                <div class="item-left">
                    <span class="position-title">{{this.title}}</span>
                </div>
                <div class="item-right">
                    <span class="date">{{this.dateRange}}</span>
                </div>
            </div>
            {{#if this.description}}
            <div class="description">{{{this.description}}}</div>
            {{/if}}
            {{#if this.achievements}}
            <ul class="item-bullets">
                {{#each this.achievements}}
                <li>{{{this}}}</li>
                {{/each}}
            </ul>
            {{/if}}
        </div>
        {{/each}}
    </section>
    {{/if}}

    {{! =========== PROJECTS =========== }}
    {{#if projects}}
    <section>
        <h2 class="section-header">{{t "resume.projects" language}}</h2>
        {{#each projects}}
        <div class="entry project-entry">
            <div class="item-row">
                <div class="item-left">
                    <span class="organization-name">{{this.name}}</span>
                </div>
                {{#if this.date}}
                <div class="item-right">
                    <span class="date">{{this.date}}</span>
                </div>
                {{/if}}
            </div>
            {{#if this.description}}
            <div class="description">{{{this.description}}}</div>
            {{/if}}
            {{#if this.highlights}}
            <ul class="item-bullets">
                {{#each this.highlights}}
                <li>{{{this}}}</li>
                {{/each}}
            </ul>
            {{/if}}
        </div>
        {{/each}}
    </section>
    {{/if}}

    {{! =========== CERTIFICATIONS =========== }}
    {{#if certifications}}
    <section>
        <h2 class="section-header">{{t "resume.certifications" language}}</h2>
        {{#each certifications}}
        <div class="entry certification-entry">
            <div class="item-row">
                <div class="item-left">
                    <span class="organization-name">{{this.name}}</span>
                </div>
                {{#if this.date}}
                <div class="item-right">
                    <span class="date">{{this.date}}</span>
                </div>
                {{/if}}
            </div>
            <div class="item-row">
                <div class="item-left">
                    <span class="description">{{this.issuer}}</span>
                </div>
            </div>
        </div>
        {{/each}}
    </section>
    {{/if}}

    {{! =========== SKILLS & INTERESTS =========== }}
    {{#if skillCategories}}
    <section class="skills-section">
        <h2 class="section-header">{{t "resume.skills" language}}</h2>
        {{#each skillCategories}}
        <div class="skill-line">
            <span class="skill-type">{{#if this.type}}{{this.type}}: {{/if}}</span>
            <span class="skill-items">{{#each this.skills}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</span>
        </div>
        {{/each}}
    </section>
    {{/if}}

    {{! =========== LANGUAGES =========== }}
    {{#if languages}}
    <section>
        <h2 class="section-header">{{t "resume.languages" language}}</h2>
        <div class="skill-line">
            <span class="skill-type">{{t "resume.languages" language}}:</span>
            <span class="skill-items">
                {{#each languages}}
                <span class="language-item">{{translateLang this.name @root.language}}{{#if this.level}} ({{t this.level @root.language}}){{/if}}</span>{{#unless @last}}, {{/unless}}
                {{/each}}
            </span>
        </div>
    </section>
    {{/if}}
</div>
</body>
</html>
