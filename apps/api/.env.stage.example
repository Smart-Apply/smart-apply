# Stage-specific overrides — copy to `.env.local` / `.env.dev` / `.env.int`
# / `.env.prod` and edit. Selected at runtime via `APP_ENV` (default: local).
#
# Loading order (FIRST wins):
#   1. .env.${APP_ENV}    ← stage-specific overrides
#   2. .env               ← shared base (committed values + secrets)
#
# Anything set in the stage file overrides the same key in `.env`. Unset
# keys fall through to `.env`.
#
# Usage:
#   APP_ENV=local npm run start:dev    # default — same as plain `npm run start:dev`
#   APP_ENV=dev   npm run start:dev
#   APP_ENV=int   npm run start:prod
#   APP_ENV=prod  npm run start:prod
#
# Common keys to override per stage:
#
# DATABASE_URL=postgresql://user:pass@host:5432/smartapply
# CORS_ORIGINS=https://app.smart-apply.io
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=smart-apply-prod
# R2_ENDPOINT=https://<account-id>.eu.r2.cloudflarestorage.com
# JOBS_DRIVER=qstash
# QSTASH_TOKEN=...
# QSTASH_CURRENT_SIGNING_KEY=...
# QSTASH_NEXT_SIGNING_KEY=...
# LLM_PROVIDER=azure-openai
# AZURE_OPENAI_ENDPOINT=...
# AZURE_OPENAI_API_KEY=...
# SENTRY_DSN=...
# ENABLE_CSRF=true
