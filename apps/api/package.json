{
  "name": "@smart-apply/api",
  "version": "1.0.0",
  "description": "Smart Apply Backend API - NestJS + Prisma + Azure",
  "author": "Smart Apply Team",
  "private": true,
  "license": "BUSL-1.1",
  "scripts": {
    "postinstall": "npx prisma generate --schema=./prisma/schema.prisma && node scripts/sanitize-prisma-client.js || true",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch --preserveWatchOutput",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node ../../dist/apps/api/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "node --inspect-brk ../../node_modules/.bin/vitest run --pool=forks --poolOptions.forks.singleFork=true",
    "test:unit": "vitest run unit.spec",
    "test:unit:watch": "vitest unit.spec",
    "test:unit:cov": "vitest run --coverage unit.spec",
    "test:integration": "NODE_ENV=test vitest run integration.spec",
    "test:integration:watch": "NODE_ENV=test vitest integration.spec",
    "test:integration:cov": "NODE_ENV=test vitest run --coverage integration.spec",
    "test:e2e": "NODE_ENV=test vitest run e2e-spec",
    "test:e2e:watch": "NODE_ENV=test vitest e2e-spec",
    "test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
    "test:all:cov": "pnpm run test:unit:cov && pnpm run test:integration:cov && pnpm run test:e2e",
    "test:setup": "../../scripts/setup-tests.sh",
    "test:cleanup": "../../scripts/cleanup-tests.sh",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma && node scripts/sanitize-prisma-client.js",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:seed": "dotenv -e .env -- ts-node -r tsconfig-paths/register prisma/seed.ts",
    "prisma:seed:templates": "dotenv -e .env -- ts-node -r tsconfig-paths/register prisma/seed-templates-autodiscover.ts",
    "prisma:seed:templates:legacy": "dotenv -e .env -- ts-node -r tsconfig-paths/register prisma/seed-multilingual-templates.ts",
    "prisma:cleanup:templates": "dotenv -e .env -- ts-node -r tsconfig-paths/register prisma/cleanup-old-templates.ts",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma",
    "template:create": "ts-node -r tsconfig-paths/register scripts/create-template.ts",
    "templates:generate-previews": "dotenv -e .env -- ts-node -r tsconfig-paths/register scripts/generate-template-previews.ts",
    "templates:regenerate-previews": "dotenv -e .env -- ts-node -r tsconfig-paths/register scripts/generate-template-previews.ts --force",
    "templates:seed-with-previews": "pnpm run prisma:seed:templates && pnpm run templates:generate-previews",
    "templates:cleanup": "ts-node -r tsconfig-paths/register scripts/cleanup-legacy-templates.ts",
    "create-agents": "ts-node -r tsconfig-paths/register scripts/create-agents.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@azure/ai-agents": "^1.0.0",
    "@azure/identity": "^4.0.0",
    "@azure/keyvault-secrets": "^4.8.0",
    "@napi-rs/canvas": "^0.1.86",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^6.19.2",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/node": "^10.50.0",
    "@sentry/profiling-node": "^10.50.0",
    "@smart-apply/shared": "workspace:*",
    "@types/opossum": "^8.1.9",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.37.0",
    "argon2": "^0.44.0",
    "axios": "^1.6.5",
    "cheerio": "^1.0.0-rc.12",
    "class-transformer": "^0.5.1",
