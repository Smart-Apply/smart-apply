{
  "name": "@smart-apply/api",
  "version": "1.0.0",
  "description": "Smart Apply Backend API - NestJS + Prisma + Azure",
  "author": "Smart Apply Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "postinstall": "npx prisma generate --schema=./prisma/schema.prisma || true",
    "build": "nest build && npm run copy:assets",
    "copy:assets": "mkdir -p ../../dist/templates ../../dist/styles && cp -r src/pdf/templates/*.hbs ../../dist/templates/ && cp -r src/pdf/styles/*.css ../../dist/styles/ 2>/dev/null || true",
    "start": "nest start",
    "start:dev": "nest start --watch --preserveWatchOutput",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node ../../dist/apps/api/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register ../../node_modules/.bin/jest --runInBand",
    "test:unit": "jest --config ./test/jest-unit.json",
    "test:unit:watch": "jest --config ./test/jest-unit.json --watch",
    "test:unit:cov": "jest --config ./test/jest-unit.json --coverage",
    "test:integration": "NODE_ENV=test jest --config ./test/jest-integration.json --runInBand",
    "test:integration:watch": "NODE_ENV=test jest --config ./test/jest-integration.json --watch --runInBand",
    "test:integration:cov": "NODE_ENV=test jest --config ./test/jest-integration.json --coverage --runInBand",
    "test:e2e": "NODE_ENV=test jest --config ./test/jest-e2e.json --runInBand --forceExit",
    "test:e2e:watch": "NODE_ENV=test jest --config ./test/jest-e2e.json --watch --runInBand",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:all:cov": "npm run test:unit:cov && npm run test:integration:cov && npm run test:e2e",
    "test:setup": "../../scripts/setup-tests.sh",
    "test:cleanup": "../../scripts/cleanup-tests.sh",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:seed": "dotenv -e .env -- ts-node -r tsconfig-paths/register prisma/seed.ts",
    "prisma:seed:templates": "dotenv -e .env -- ts-node -r tsconfig-paths/register prisma/seed-multilingual-templates.ts",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma",
    "create-agents": "ts-node -r tsconfig-paths/register scripts/create-agents.ts"
  },
  "dependencies": {
    "@azure/ai-agents": "^1.0.0",
    "@azure/identity": "^4.0.0",
    "@azure/keyvault-secrets": "^4.8.0",
    "@azure/service-bus": "^7.9.4",
    "@azure/storage-blob": "^12.17.0",
    "@huggingface/inference": "^4.13.0",
    "@langchain/core": "^1.0.3",
    "@langchain/langgraph": "^1.0.1",
    "@langchain/openai": "^1.0.0",
    "@nestjs/axios": "^3.0.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/terminus": "^10.2.0",
    "@nestjs/throttler": "^5.1.1",
    "@prisma/client": "^5.8.0",
    "@smart-apply/shared": "1.0.0",
    "argon2": "^0.31.2",
    "axios": "^1.6.5",
    "cheerio": "^1.0.0-rc.12",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.3",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "langchain": "^1.0.3",
    "langchain-core": "^0.0.4",
    "mammoth": "^1.6.0",
    "passport": "^0.7.0",
    "passport-azure-ad": "^4.3.5",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pino": "^8.17.2",
    "pino-http": "^9.0.0",
    "pino-pretty": "^10.3.1",
    "playwright": "^1.56.1",
    "puppeteer": "^21.7.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.0",
    "ua-parser-js": "^1.0.41",
    "validator": "^13.15.23",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/cheerio": "^1.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/handlebars": "^4.0.40",
    "@types/multer": "^1.4.11",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/ua-parser-js": "^0.7.39",
    "@types/validator": "^13.15.9",
    "baseline-browser-mapping": "^2.9.3"
  },
  "prisma": {
    "seed": "node prisma/dist/seed-all.js"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
