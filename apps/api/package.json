    "otplib": "^13.2.1",
    "passport": "^0.7.0",
    "passport-azure-ad": "^4.3.5",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-microsoft": "^2.1.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.13.1",
    "pino": "^8.17.2",
    "pino-http": "^11.0.0",
    "pino-pretty": "^10.3.1",
    "playwright": "^1.56.1",
