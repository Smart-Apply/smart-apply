# ================================================================
# Smart Apply - Production Environment Configuration
# ================================================================
# This file contains production-ready environment variables for 
# Azure Container Apps deployment. Replace placeholder values 
# with your actual Azure resource credentials.
# ================================================================

# ----------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------
# Azure Database for PostgreSQL - Flexible Server
# Format: postgresql://username:password@hostname:5432/database?sslmode=require
DATABASE_URL=postgresql://smartapply_admin:<PASSWORD>@smartapply-db.postgres.database.azure.com:5432/smartapply?sslmode=require

# ----------------------------------------------------------------
# Security - JWT Authentication
# ----------------------------------------------------------------
# CRITICAL: Generate with: openssl rand -base64 64
# Store in Azure Key Vault and reference here
JWT_SECRET=<YOUR_PRODUCTION_JWT_SECRET_MINIMUM_64_CHARACTERS>

# JWT token expiration (7 days for production)
JWT_EXPIRES_IN=7d

# ----------------------------------------------------------------
# Security - CORS
# ----------------------------------------------------------------
# Production frontend domain(s) - comma-separated, no spaces
# Example: https://app.smartapply.com,https://smartapply.azurestaticapps.net
CORS_ORIGINS=https://your-frontend-domain.com

# ----------------------------------------------------------------
# Security - Rate Limiting (Production - Strict)
# ----------------------------------------------------------------
# Standard endpoints: 100 requests per 15 minutes
RATE_LIMIT_TTL=900
RATE_LIMIT_MAX=100

# Auth endpoints: 5 attempts per 15 minutes (STRICT)
RATE_LIMIT_AUTH_TTL=900
RATE_LIMIT_AUTH_MAX=5

# ----------------------------------------------------------------
# Security - CSRF Protection
# ----------------------------------------------------------------
# Enable CSRF protection for production (recommended)
ENABLE_CSRF=true

# ----------------------------------------------------------------
# Azure Storage (Blob)
# ----------------------------------------------------------------
# Storage driver: azure for production
STORAGE_DRIVER=azure

# Azure Storage Account name (without .blob.core.windows.net)
AZURE_STORAGE_ACCOUNT=<YOUR_STORAGE_ACCOUNT_NAME>

# Container name for PDF uploads
AZURE_STORAGE_CONTAINER=smartapply-pdfs

# Connection string (get from Azure Portal > Storage Account > Access Keys)
# Store in Azure Key Vault and reference as @Microsoft.KeyVault(SecretUri=...)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<ACCOUNT>;AccountKey=<KEY>;EndpointSuffix=core.windows.net

# ----------------------------------------------------------------
# Azure Service Bus (Jobs/Queue)
# ----------------------------------------------------------------
# Jobs provider: service-bus for production
JOBS_PROVIDER=service-bus

# Service Bus namespace connection string
# Get from Azure Portal > Service Bus > Shared access policies > RootManageSharedAccessKey
# Store in Azure Key Vault and reference as @Microsoft.KeyVault(SecretUri=...)
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://<YOUR_NAMESPACE>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<KEY>

# Queue name for application processing jobs
SERVICE_BUS_QUEUE_NAME=application-processing

# ----------------------------------------------------------------
# Azure Key Vault
# ----------------------------------------------------------------
# Key Vault URI for secrets management
# Format: https://<vault-name>.vault.azure.net/
KEY_VAULT_URI=https://<YOUR_KEY_VAULT_NAME>.vault.azure.net/

# ----------------------------------------------------------------
# Azure OpenAI (LLM Provider)
# ----------------------------------------------------------------
# LLM provider: azure-openai for production
LLM_PROVIDER=azure-openai

# Azure OpenAI endpoint URL
# Format: https://<resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://<YOUR_AZURE_OPENAI_RESOURCE>.openai.azure.com/

# Azure OpenAI API key
# Get from Azure Portal > Azure OpenAI > Keys and Endpoint
# Store in Azure Key Vault and reference as @Microsoft.KeyVault(SecretUri=...)
AZURE_OPENAI_API_KEY=<YOUR_AZURE_OPENAI_API_KEY>

# Azure OpenAI deployment name (e.g., gpt-4, gpt-35-turbo)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Azure OpenAI API version
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ----------------------------------------------------------------
# PDF Generation (Puppeteer)
# ----------------------------------------------------------------
# Puppeteer executable path for Azure Container Apps
# Use bundled Chromium (leave empty for auto-detection)
PUPPETEER_EXECUTABLE_PATH=

# Puppeteer args for containerized environment (pre-configured in service)
# Default: --no-sandbox,--disable-setuid-sandbox,--single-process,--disable-gpu

# ----------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------
# Node environment
NODE_ENV=production

# Application port (Azure Container Apps default)
PORT=3000

# API version prefix
API_PREFIX=api/v1

# ----------------------------------------------------------------
# Logging & Monitoring
# ----------------------------------------------------------------
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable structured JSON logging for Azure Monitor
LOG_JSON=true

# ----------------------------------------------------------------
# Optional: Azure Application Insights
# ----------------------------------------------------------------
# Application Insights connection string
# Get from Azure Portal > Application Insights > Properties
# APPINSIGHTS_INSTRUMENTATIONKEY=<YOUR_INSTRUMENTATION_KEY>
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentmentationKey=<KEY>;IngestionEndpoint=https://<REGION>.in.applicationinsights.azure.com/

# ----------------------------------------------------------------
# Optional: Managed Identity (Recommended)
# ----------------------------------------------------------------
# Use Azure Managed Identity instead of connection strings
# Uncomment to enable (requires Container Apps managed identity setup)
# AZURE_USE_MANAGED_IDENTITY=true

# ----------------------------------------------------------------
# Health Check Configuration
# ----------------------------------------------------------------
# Health check endpoint timeout (seconds)
HEALTH_CHECK_TIMEOUT=10

# Database health check enabled
HEALTH_CHECK_DATABASE=true

# ----------------------------------------------------------------
# Cookie Configuration (Production - Secure)
# ----------------------------------------------------------------
# Cookie settings are auto-configured in production mode:
# - HttpOnly: true (XSS protection)
# - Secure: true (HTTPS only)
# - SameSite: strict (CSRF protection)
# - Domain: auto-detected from request
# - MaxAge: 7 days (604800000 ms)

# ----------------------------------------------------------------
# Refresh Token Configuration (Issue #98)
# ----------------------------------------------------------------
# Refresh token secret (generate separately from JWT_SECRET)
# Generate with: openssl rand -base64 64
REFRESH_TOKEN_SECRET=<YOUR_PRODUCTION_REFRESH_TOKEN_SECRET>

# Refresh token expiration (30 days)
REFRESH_TOKEN_EXPIRES_IN=30d

# ----------------------------------------------------------------
# DEPLOYMENT NOTES
# ================================================================
# 1. Replace all placeholder values (<YOUR_...>) with actual Azure resource values
# 2. Generate secure secrets with: openssl rand -base64 64
# 3. Store sensitive values in Azure Key Vault
# 4. Reference Key Vault secrets in Azure Container Apps:
#    @Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/<name>)
# 5. Enable Managed Identity for Container Apps to access Key Vault
# 6. Configure custom domain and HTTPS in Azure Container Apps
# 7. Set CORS_ORIGINS to your actual frontend domain
# 8. Review rate limiting settings based on expected traffic
# 9. Enable Application Insights for monitoring and diagnostics
# 10. Test all Azure service connections before deployment
# ================================================================
