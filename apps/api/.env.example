# ─────────────────────────────────────────────────────────────────────────────
# Smart Apply API — local development environment template.
#
# Copy this file to `.env` and fill in real values:
#   cp apps/api/.env.example apps/api/.env
#
# Never commit `.env`. Staging & prod read their values from Fly Secrets,
# not from a committed file.
# ─────────────────────────────────────────────────────────────────────────────

# Node Environment
NODE_ENV=development
PORT=3000

# Logging: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ─── Database ────────────────────────────────────────────────────────────────
# Default: local Docker Postgres (`docker compose -f infra/docker-compose.yml up -d`).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartapply
# DIRECT_URL is only required when DATABASE_URL points at a transaction-mode
# pooler (Neon pgbouncer, Supabase Supavisor). Optional for plain Postgres.
# DIRECT_URL=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64  (must be 64+ chars)
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_64_OUTPUT_AT_LEAST_64_CHARACTERS_LONG
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_EXPIRES_IN=15m

# ─── Storage (disk | r2) ─────────────────────────────────────────────────────
STORAGE_DRIVER=disk
# R2 (used when STORAGE_DRIVER=r2). EU-jurisdiction bucket for GDPR.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=smart-apply-dev
# R2_ENDPOINT=https://<account-id>.eu.r2.cloudflarestorage.com

# ─── Job Queue (in-memory | qstash) ──────────────────────────────────────────
JOBS_DRIVER=in-memory
# QStash needs a public webhook URL — use ngrok/cloudflared for local dev.
# QSTASH_URL=https://qstash-eu-central-1.upstash.io
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=
# QSTASH_WEBHOOK_URL=

# ─── Rate Limit Storage (memory | upstash) ───────────────────────────────────
THROTTLER_STORAGE=memory
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── LLM Provider (mock | azure-openai | azure-ai-foundry) ───────────────────
# Use 'azure-openai' when iterating on prompts; 'mock' for UI/auth work.
LLM_PROVIDER=mock
LLM_TEMPERATURE_DEFAULT=0.5
LLM_MAX_TOKENS_DEFAULT=3000
LOG_LLM_CALLS=false

# Azure OpenAI (used when LLM_PROVIDER=azure-openai)
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
# AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure AI Foundry (used when LLM_PROVIDER=azure-ai-foundry)
# AZURE_AI_FOUNDRY_API_KEY=
# PROJECT_ENDPOINT=
# ATS_AGENT_ID=
# CV_WRITER_AGENT_ID=
# CL_WRITER_AGENT_ID=

# Circuit breaker around the LLM provider
LLM_CIRCUIT_BREAKER_TIMEOUT=60000
LLM_CIRCUIT_BREAKER_ERROR_THRESHOLD=50
LLM_CIRCUIT_BREAKER_RESET_TIMEOUT=30000
LLM_CIRCUIT_BREAKER_ROLLING_COUNT_TIMEOUT=10000
LLM_CIRCUIT_BREAKER_ROLLING_COUNT_BUCKETS=10

# ─── Agent URL Parser (Playwright + Azure OpenAI) ────────────────────────────
ENABLE_AGENT_PARSER=true
AGENT_MAX_STEPS=10
AGENT_TIMEOUT=30000

# ─── PDF Generation ──────────────────────────────────────────────────────────
# Leave commented to let Puppeteer auto-detect Chromium.
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PUPPETEER_MAX_BROWSERS=5
PUPPETEER_MIN_BROWSERS=0
PUPPETEER_IDLE_TIMEOUT_MS=60000
PUPPETEER_EVICTION_INTERVAL_MS=60000

# ─── File Upload Limits ──────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_PROFILE_PHOTO_SIZE_MB=5

# ─── Security ────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CSP_REPORT_ONLY=false
ENABLE_CSRF=false
ENABLE_COMPRESSION=true
ENABLE_CRON_JOBS=false

# ─── Rate Limiting (relaxed for dev) ─────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100000
RATE_LIMIT_AUTH_TTL=900
RATE_LIMIT_AUTH_MAX=15

# ─── Misc ────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
REQUEST_TIMEOUT_MS=30000

# Two-Factor Authentication. Generate with: openssl rand -hex 32
TWO_FACTOR_ENCRYPTION_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32_OUTPUT

# ─── OAuth (optional — leave blank to disable that provider locally) ─────────
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Free sandbox sender works without verifying a domain.
# RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
APP_URL=http://localhost:3001

# ─── Third-Party APIs ────────────────────────────────────────────────────────
# APIFY_TOKEN=

# ─── Production-only (DO NOT set locally) ────────────────────────────────────
# KEY_VAULT_URI=
# SENTRY_DSN=

# ─── Email Tracking (Premium) — OAuth Inbox Sync ─────────────────────────────
# AES-256-GCM key used to encrypt persisted OAuth refresh tokens in
# `mailbox_connections`. Generate with: openssl rand -hex 32
# When unset, the mailbox-sync module refuses to connect new mailboxes.
# MAILBOX_TOKEN_ENCRYPTION_KEY=

# Microsoft Entra ID app for the inbox sync. SEPARATE app from the social
# login one above — this one needs the `Mail.Read` + `offline_access`
# scopes (delegated permissions). Add a Web redirect URI of
# https://<api-host>/api/v1/mailbox-sync/microsoft/callback in the Azure
# portal. Tenant `common` accepts both work and personal accounts.
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# MS_GRAPH_TENANT=common

# Where the user is sent after a successful OAuth round-trip.
# Defaults to APP_URL + '/settings?email_tracking=connected'.
# MS_GRAPH_POST_CONNECT_REDIRECT=

# Renew Graph subscriptions when they have less than this many minutes
# remaining. Default 360 (6h) — Graph caps subscription lifetime at ~70.5h.
# MAILBOX_SUBSCRIPTION_RENEWAL_MARGIN_MINUTES=360
