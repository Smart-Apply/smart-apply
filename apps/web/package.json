{
  "name": "@smart-apply/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "echo '\\n⚠️  npm start runs the PRODUCTION build (next start). Did you mean `npm run dev`?\\n     If you really want production locally, run: npm run start:prod-local\\n' && exit 1",
    "start:prod-local": "next start -p 3001",
    "lint": "eslint",
    "cf:hide-local-env": "test ! -f .env || mv .env .env.bak",
    "cf:restore-local-env": "test ! -f .env.bak || mv .env.bak .env",
    "cf:build": "npm run cf:hide-local-env && (NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL:-https://api.smart-apply.io/api/v1} NEXT_PUBLIC_TURNSTILE_SITE_KEY=${NEXT_PUBLIC_TURNSTILE_SITE_KEY:-0x4AAAAAADEb1zo5z5Pb47Dz} OPEN_NEXT=true opennextjs-cloudflare build); status=$?; npm run cf:restore-local-env; exit $status",
    "cf:preview": "npm run cf:build && OPEN_NEXT=true opennextjs-cloudflare preview",
    "cf:deploy": "npm run cf:build && OPEN_NEXT=true opennextjs-cloudflare deploy",
    "cf:upload": "npm run cf:build && OPEN_NEXT=true opennextjs-cloudflare upload"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@smart-apply/shared": "1.0.0",
    "@tanstack/react-query": "^5.90.7",
    "@tiptap/extension-text-style": "^3.14.0",
    "@tiptap/react": "^3.10.5",
    "@tiptap/starter-kit": "^3.10.5",
    "@types/turndown": "^5.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "handlebars": "^4.7.8",
    "isomorphic-dompurify": "^2.32.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "next": "^16.1.4",
    "pdfjs-dist": "^5.4.296",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.66.0",
    "react-pdf": "^10.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "turndown": "^7.2.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.0.10",
    "@opennextjs/cloudflare": "^1.19.4",
    "@tailwindcss/postcss": "^4",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.9.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wrangler": "^4.85.0"
  }
}
