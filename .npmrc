# pnpm configuration. See https://pnpm.io/npmrc for the full list.

# Auto-install peer dependencies — pnpm 8+ default. Mirrors what npm does
# silently, so projects that worked under npm install continue to work.
auto-install-peers=true

# Don't fail the install when a peer dep is missing or wrong version. We
# previously needed `--legacy-peer-deps` under npm for the same reason
# (mainly @nestjs/common ↔ @nestjs/throttler version skew). Tighten this
# back to `true` when we're peer-clean.
strict-peer-dependencies=false

# Keep pnpm's default isolated node_modules layout. If a tool ever blows
# up with "cannot find module" because it does its own resolution outside
# the symlink tree, add a targeted `public-hoist-pattern[]=` entry rather
# than flipping `shamefully-hoist=true`.
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
