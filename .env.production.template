# Production Environment Configuration Template
# Copy this file to .env.production and fill in the values

# ===================================
# CRITICAL: Generate Secure Secrets
# ===================================
# Generate JWT secrets with: openssl rand -base64 64
# Generate PostgreSQL password with: openssl rand -base64 32

# Node Environment
NODE_ENV=production
PORT=3000

# ===================================
# Database (Azure PostgreSQL)
# ===================================
# Format: postgresql://USERNAME:PASSWORD@SERVER.postgres.database.azure.com:5432/smartapply?sslmode=require
DATABASE_URL=

# ===================================
# Authentication & Security
# ===================================
# CRITICAL: Generate with openssl rand -base64 64
JWT_SECRET=
REFRESH_TOKEN_SECRET=

# Token expiration
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ===================================
# Storage (Azure Blob)
# ===================================
STORAGE_DRIVER=azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=applications

# ===================================
# Jobs/Queue (Azure Service Bus)
# ===================================
JOBS_DRIVER=service-bus
SERVICE_BUS_CONNECTION_STRING=
SERVICE_BUS_QUEUE_NAME=applications

# ===================================
# LLM Provider
# ===================================
# Options: mock | azure-openai | azure-ai-foundry | huggingface
LLM_PROVIDER=azure-openai

# Azure OpenAI (if LLM_PROVIDER=azure-openai)
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure AI Foundry (if LLM_PROVIDER=azure-ai-foundry)
AZURE_AI_FOUNDRY_API_KEY=
AZURE_AI_FOUNDRY_PROJECT_CONNECTION_STRING=

# Hugging Face (if LLM_PROVIDER=huggingface)
HUGGINGFACE_API_KEY=

# ===================================
# Agent Settings (for URL parsing)
# ===================================
ENABLE_AGENT_PARSER=true
AGENT_MAX_STEPS=10
AGENT_TIMEOUT=30000

# ===================================
# PDF Generation (Puppeteer)
# ===================================
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ===================================
# Security Settings
# ===================================
# CORS: Comma-separated frontend URLs
CORS_ORIGINS=https://smartapply.vercel.app,https://www.smartapply.com

# Rate Limiting - Standard endpoints
RATE_LIMIT_TTL=900              # 15 minutes in seconds
RATE_LIMIT_MAX=300              # 300 requests per 15 minutes (production)

# Rate Limiting - Auth endpoints (stricter)
RATE_LIMIT_AUTH_TTL=900         # 15 minutes
RATE_LIMIT_AUTH_MAX=5           # 5 attempts per 15 minutes

# CSRF Protection (RECOMMENDED for production)
ENABLE_CSRF=true

# ===================================
# Azure Key Vault (Optional)
# ===================================
# Use Key Vault references in Container Apps instead of direct secrets
KEY_VAULT_URI=https://smartapply-prod-kv.vault.azure.net/

# ===================================
# Logging & Monitoring
# ===================================
LOG_LEVEL=info
LOG_PRETTY=false                # Disable pretty logging in production (use JSON)

# ===================================
# Application Insights (Optional)
# ===================================
# APPINSIGHTS_CONNECTION_STRING=
