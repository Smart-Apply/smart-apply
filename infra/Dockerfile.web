# syntax=docker/dockerfile:1
# Optimized Next.js Dockerfile
# Expected size reduction: ~238MB → ~150MB

# Stage 1: Dependencies (production only)
FROM node:20-alpine AS deps
WORKDIR /app

# Install dependencies for native modules
RUN apk add --no-cache libc6-compat

# Copy root package files (needed for workspace)
COPY package.json package-lock.json ./

# Create apps directory structure
RUN mkdir -p apps/web packages/shared

# Copy Web package.json
COPY apps/web/package.json ./apps/web/

# Copy packages/shared (required dependency)
COPY packages/shared/package.json ./packages/shared/
COPY packages/shared/tsconfig.json ./packages/shared/
COPY packages/shared/src ./packages/shared/src

# Install only production dependencies for web workspace
RUN --mount=type=cache,target=/root/.npm \
    npm ci --workspace=apps/web --workspace=packages/shared --omit=dev --legacy-peer-deps

# Stage 2: Builder
FROM node:20-alpine AS builder
WORKDIR /app

# Install dependencies for native modules
RUN apk add --no-cache libc6-compat

# Copy root package files (needed for workspace)
COPY package.json package-lock.json ./

# Create apps directory structure
RUN mkdir -p apps/web packages/shared

# Copy Web package.json
COPY apps/web/package.json ./apps/web/

# Copy packages/shared (required dependency)
COPY packages/shared/package.json ./packages/shared/
COPY packages/shared/tsconfig.json ./packages/shared/
COPY packages/shared/src ./packages/shared/src

# Install ALL dependencies (including devDependencies for build)
RUN --mount=type=cache,target=/root/.npm \
    npm ci --workspace=apps/web --workspace=packages/shared --legacy-peer-deps

# Copy Web source code and config
COPY apps/web/src ./apps/web/src
COPY apps/web/public ./apps/web/public
COPY apps/web/tsconfig.json ./apps/web/
COPY apps/web/next.config.ts ./apps/web/
COPY apps/web/postcss.config.mjs ./apps/web/
COPY apps/web/eslint.config.mjs ./apps/web/
COPY apps/web/components.json ./apps/web/

# Accept build argument for API URL
ARG NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Sentry build-time vars (NEXT_PUBLIC_* get baked into the client bundle).
# Empty default → Sentry stays a no-op when not configured.
ARG NEXT_PUBLIC_SENTRY_DSN=
ARG NEXT_PUBLIC_SENTRY_RELEASE=

# Set environment variables for optimal build
ENV NEXT_TELEMETRY_DISABLED=1 \
    NODE_ENV=production \
    NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL} \
    NEXT_PUBLIC_SENTRY_DSN=${NEXT_PUBLIC_SENTRY_DSN} \
    NEXT_PUBLIC_SENTRY_RELEASE=${NEXT_PUBLIC_SENTRY_RELEASE}

# Build shared package first (required by web)
WORKDIR /app
RUN npm run shared:build

# Build the Next.js app
WORKDIR /app/apps/web
RUN npm run build

# Stage 3: Runner (minimal runtime)
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3001 \
    HOSTNAME="0.0.0.0"

# Install dumb-init for proper signal handling and wget for healthcheck
RUN apk add --no-cache dumb-init wget && \
    rm -rf /var/cache/apk/*

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy standalone build (automatically includes minimal node_modules)
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

# Copy public folder to correct location (relative to server.js in apps/web/)
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

USER nextjs

EXPOSE 3001

# Use dumb-init for proper signal handling
CMD ["dumb-init", "node", "apps/web/server.js"]
