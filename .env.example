# Node Environment
NODE_ENV=development
PORT=3000

# Logging
# Log level for Pino (trace | debug | info | warn | error | fatal | silent)
# Default: info
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartapply

# Database Connection Pool Settings (optional, has smart defaults per environment)
# Maximum connections in the pool (default: 10 dev, 20 prod)
# DB_POOL_MAX=20
# Minimum connections to keep warm (default: 2 dev, 5 prod)
# DB_POOL_MIN=5
# Close idle connections after N milliseconds (default: 30000 dev, 60000 prod)
# DB_IDLE_TIMEOUT=60000
# Connection acquisition timeout in milliseconds (default: 5000 dev, 3000 prod)
# DB_CONNECTION_TIMEOUT=3000

# Read Replica (optional, for production scaling)
# Offload read queries to replica for better performance
# DATABASE_URL_READ=postgresql://postgres:postgres@read-replica.example.com:5432/smartapply

# JWT
# CRITICAL: Generate a secure JWT secret with: openssl rand -base64 64
# Must be 64+ characters for production use
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_SECRET_MINIMUM_64_CHARACTERS_USE_OPENSSL_RAND_BASE64_64
# Short-lived access tokens (15 minutes recommended)
JWT_ACCESS_EXPIRES_IN=15m
# Long-lived refresh tokens (30 days recommended)
JWT_REFRESH_EXPIRES_IN=30d
# Legacy support (will use JWT_ACCESS_EXPIRES_IN if not set)
JWT_EXPIRES_IN=15m

# Storage (disk | azure | r2)
STORAGE_DRIVER=disk
# AZURE_STORAGE_ACCOUNT=your_storage_account
# AZURE_STORAGE_CONTAINER=smartapply
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Cloudflare R2 (S3-compatible) — used when STORAGE_DRIVER=r2
# Get from: https://dash.cloudflare.com/?to=/:account/r2/api-tokens
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key_id
# R2_SECRET_ACCESS_KEY=your_secret_access_key
# R2_BUCKET=smart-apply-prod
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com  # optional override

# Distributed rate-limit storage backend (memory | upstash)
# memory  → single-instance, lost on restart (dev / single-VM)
# upstash → shared across all API instances via Upstash Redis (REST)
THROTTLER_STORAGE=memory

# Upstash Redis (REST) — required when THROTTLER_STORAGE=upstash
# Free tier: 10k commands/day. Get keys at https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<token>

# Azure Service Bus (required for production background jobs)
# Local development uses in-memory queue by default
# Set JOBS_DRIVER=service-bus to use Azure Service Bus
#
# Connection String format:
# Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<keyName>;SharedAccessKey=<key>
#
# Queue Configuration (recommended settings):
# - Max Delivery Count: 5 (max retries before dead-letter)
# - Lock Duration: 5 minutes (PT5M)
# - Message TTL: 14 days (P14D)
# - Dead-lettering on expiration: enabled
#
# Jobs Queue Driver (in-memory | service-bus | qstash)
JOBS_DRIVER=in-memory
# SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key
# SERVICE_BUS_QUEUE_NAME=smartapply-jobs

# Upstash QStash (managed serverless queue) — used when JOBS_DRIVER=qstash
# Free tier: 500 messages/day. Get keys at https://console.upstash.com/qstash
# QStash POSTs job webhooks to a public URL — your API must be reachable.
# Local dev with QStash requires a tunnel (ngrok, cloudflared) since
# QStash can't reach localhost:3000.
# QSTASH_URL=https://qstash-eu-central-1.upstash.io
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=
# QSTASH_WEBHOOK_URL=https://api.smart-apply.io/api/v1/jobs/qstash-webhook

# Azure Key Vault (optional for production secrets)
# KEY_VAULT_URI=https://your-keyvault.vault.azure.net/

# LLM Provider (mock | azure-openai | azure-ai-foundry | huggingface)
LLM_PROVIDER=mock

# Azure OpenAI Configuration
# AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_api_key
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure AI Foundry Agents Configuration
# Use specialized AI agents deployed in Azure AI Foundry for resume and cover letter generation
# Falls back to Azure OpenAI if agents fail, so both configurations should be provided
# Azure AI Foundry Agents (requires running: npm run create-agents first)
# PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
# CV_WRITER_AGENT_ID=agent_xxx
# CL_WRITER_AGENT_ID=agent_yyy

# PDF Generation
# Path to Chromium executable (leave empty to use bundled Chromium)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Browser Pooling Configuration
# Maximum concurrent browser instances (default: 5)
# Formula: (cpu_cores × 2) + 1
# Example: 2 cores = 5 browsers, 4 cores = 9 browsers
PUPPETEER_MAX_BROWSERS=5

# Minimum browser instances to keep alive (default: 1)
PUPPETEER_MIN_BROWSERS=1

# Close idle browsers after N milliseconds (default: 30000 = 30s)
PUPPETEER_IDLE_TIMEOUT_MS=30000

# Check for idle browsers every N milliseconds (default: 10000 = 10s)
PUPPETEER_EVICTION_INTERVAL_MS=10000

# Agent-Based URL Parser Configuration
# Enable agent-based parsing for JavaScript-heavy job sites (Indeed, LinkedIn, etc.)
ENABLE_AGENT_PARSER=true

# Agent behavior settings
AGENT_MAX_STEPS=10
AGENT_TIMEOUT=30000

# LLM for agent (uses same Azure OpenAI or OpenAI config as main LLM)
# If Azure OpenAI is configured above, agent will use it
# Otherwise, set OPENAI_API_KEY for standard OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key

# OAuth (optional)
# AZURE_AD_CLIENT_ID=your_client_id
# AZURE_AD_CLIENT_SECRET=your_client_secret
# AZURE_AD_TENANT_ID=your_tenant_id
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Security
# CORS Origins - Comma-separated list of allowed frontend origins
# Development: Use localhost URLs
# Production: MUST be set to your deployed frontend URLs (Azure, Vercel, etc.)
# Example Production: CORS_ORIGINS=https://smartapply.azurewebsites.net,https://www.smartapply.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# CSRF Protection (disabled by default for MVP)
# Set to 'true' to enable CSRF protection on POST/PUT/DELETE/PATCH requests
# Requires frontend to send X-CSRF-Token header with valid token
ENABLE_CSRF=false

# Content Security Policy (CSP)
# Set to 'true' to enable report-only mode (logs violations without blocking)
# Set to 'false' to enforce CSP (blocks violations)
# Recommended: Start with 'true' to test, then switch to 'false' for production
CSP_REPORT_ONLY=false

# Rate Limiting - Default (general API endpoints)
# TTL in seconds, applied to all endpoints except those with specific limits
# Development: 1000 requests per 15 minutes (reasonable for local testing)
# Production: Consider 300-500 based on usage patterns
RATE_LIMIT_TTL=900
RATE_LIMIT_MAX=1000

# Rate Limiting - Auth Endpoints (stricter for security)
# Prevents brute force attacks on login/register.
# CAPTCHA failures are rejected by CaptchaGuard *before* the throttler
# runs, so they no longer consume budget. This counter only ticks for
# requests that actually reach auth logic (bad password, expired tokens,
# 2FA mismatches, forgot-password sends, etc.).
RATE_LIMIT_AUTH_TTL=900
RATE_LIMIT_AUTH_MAX=15

# Cron Jobs
# Set to 'false' to disable automated cleanup jobs in local development
# Recommended: 'false' for dev, 'true' for production
ENABLE_CRON_JOBS=false

# Compression
# Set to 'true' to enable gzip compression for API responses (reduces bandwidth by 80%+)
ENABLE_COMPRESSION=true

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Caching
# Time-to-live for cached static data like templates (seconds)
# Default: 3600 seconds (1 hour)
CACHE_TTL_SECONDS=3600

# Circuit Breaker - LLM Service Protection
# Prevents cascading failures when LLM provider is degraded or unavailable
# Timeout for individual LLM requests (milliseconds)
LLM_CIRCUIT_BREAKER_TIMEOUT=60000
# Error threshold percentage (0-100) - circuit opens if this % of requests fail
LLM_CIRCUIT_BREAKER_ERROR_THRESHOLD=50
# Time to wait before trying again after circuit opens (milliseconds)
LLM_CIRCUIT_BREAKER_RESET_TIMEOUT=30000
# Rolling count window for error tracking (milliseconds)
LLM_CIRCUIT_BREAKER_ROLLING_COUNT_TIMEOUT=10000
# Number of buckets for rolling count (more = better accuracy, more memory)
LLM_CIRCUIT_BREAKER_ROLLING_COUNT_BUCKETS=10

# Global Request Timeout
# Maximum time any request can take before timing out (milliseconds)
# Prevents hanging requests from tying up worker threads
REQUEST_TIMEOUT_MS=30000


# =============================================================================
# PRODUCTION OVERRIDES (smart-apply.io)
# =============================================================================
# These values belong in /home/azureuser/smart-apply/apps/api/.env on the VM,
# NOT in this committed file. Kept here as a checklist / reference only.
#
# Lines marked CHANGEME require values you generate or sign up for.
# Copy this block into the VM's .env, fill in CHANGEME values, then restart
# the API container.
#
# NODE_ENV=production
# LOG_LEVEL=info
#
# # Database (Azure Database for PostgreSQL Flexible Server)
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/smartapply?sslmode=require  # CHANGEME
#
# # Security — generate with: openssl rand -base64 64
# JWT_SECRET=CHANGEME_64_CHARS_OR_MORE
# # 2FA: generate with: openssl rand -hex 32
# TWO_FACTOR_ENCRYPTION_KEY=CHANGEME_64_HEX_CHARS
#
# # Domain & URLs (smart-apply.io)
# CORS_ORIGINS=https://smart-apply.io,https://www.smart-apply.io
# # If you deploy the frontend on Cloudflare Workers (OpenNext) and run an
# # A/B test on a preview hostname, ALSO add it here:
# # CORS_ORIGINS=https://smart-apply.io,https://www.smart-apply.io,https://smart-apply-web.<account>.workers.dev,https://new.smart-apply.io
# APP_URL=https://smart-apply.io           # Used in email links (password reset, verify)
# API_BASE_URL=https://api.smart-apply.io  # Used for OAuth callback URLs
#
# # Rate limiting (production: stricter than dev)
# RATE_LIMIT_TTL=900       # 15 min
# RATE_LIMIT_MAX=300       # 300 req per 15 min per IP
# RATE_LIMIT_AUTH_TTL=900
# RATE_LIMIT_AUTH_MAX=15   # 15 login attempts per 15 min per IP
#
# # CSRF — recommended in production
# ENABLE_CSRF=true
#
# # Storage — switch from disk to Azure Blob OR Cloudflare R2 in production
# # Option A: Azure Blob (legacy)
# # STORAGE_DRIVER=azure
# # AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...  # CHANGEME
# # AZURE_STORAGE_CONTAINER=smartapply
# # Option B: Cloudflare R2 (recommended — no egress fees, ~10x cheaper)
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=CHANGEME
# R2_ACCESS_KEY_ID=CHANGEME
# R2_SECRET_ACCESS_KEY=CHANGEME
# R2_BUCKET=smart-apply-prod
#
# # Distributed rate limiting (recommended once API has >1 instance)
# THROTTLER_STORAGE=upstash
# UPSTASH_REDIS_REST_URL=https://<id>.upstash.io  # CHANGEME
# UPSTASH_REDIS_REST_TOKEN=CHANGEME
#
# # Job queue — switch from in-memory to Service Bus to survive container restarts
# JOBS_DRIVER=service-bus
# SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...  # CHANGEME
# SERVICE_BUS_QUEUE_NAME=application-jobs
#
# # LLM — switch from mock to real Azure OpenAI
# LLM_PROVIDER=azure-openai
# AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com/                    # CHANGEME
# AZURE_OPENAI_API_KEY=CHANGEME
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini   # cheaper for MVP, swap for gpt-4o if quality matters
# LLM_MAX_TOKENS_DEFAULT=2000
#
# # Email (Resend) — required for password reset & verification emails
# RESEND_API_KEY=re_...                    # CHANGEME (sign up at resend.com)
# EMAIL_FROM=noreply@smart-apply.io        # Verify this domain in Resend first
#
# # Puppeteer pool — tune for traffic
# PUPPETEER_MAX_BROWSERS=10
# PUPPETEER_MIN_BROWSERS=2
# # Sentry error tracking (optional)
# # Backend (NestJS): only the API DSN is read from server env
# SENTRY_DSN=https://<api-key>@o<org-id>.ingest.sentry.io/<project-id>  # CHANGEME
# SENTRY_RELEASE=                          # auto-set from CI commit SHA
# # Frontend (Next.js): the WEB DSN is baked into the client bundle at build time
# # Set as a GitHub Repository Variable (vars.SENTRY_DSN_WEB) so the deploy workflow
# # passes it as a Docker build-arg \u2014 not as a runtime env var.
