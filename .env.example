# Node Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartapply

# JWT
JWT_SECRET=change_me_to_a_strong_secret_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# Storage (disk or azure)
STORAGE_DRIVER=disk
# AZURE_STORAGE_ACCOUNT=your_storage_account
# AZURE_STORAGE_CONTAINER=smartapply
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Azure Service Bus (optional for background jobs)
# SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...
# SERVICE_BUS_QUEUE_NAME=application-jobs

# Azure Key Vault (optional for production secrets)
# KEY_VAULT_URI=https://your-keyvault.vault.azure.net/

# LLM Provider (mock | azure-openai | huggingface)
LLM_PROVIDER=mock

# Azure OpenAI Configuration
# AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_api_key
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Hugging Face Configuration
# HUGGINGFACE_API_KEY=hf_your_api_key_here
# HUGGINGFACE_MODEL=meta-llama/Llama-2-7b-chat-hf
# Alternative models:
# - mistralai/Mistral-7B-Instruct-v0.1
# - meta-llama/Llama-2-13b-chat-hf
# - tiiuae/falcon-7b-instruct

# PDF Generation
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# OAuth (optional)
# AZURE_AD_CLIENT_ID=your_client_id
# AZURE_AD_CLIENT_SECRET=your_client_secret
# AZURE_AD_TENANT_ID=your_tenant_id
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
