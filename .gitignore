# Dependencies
node_modules/
.pnp
.pnp.*
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage/
*.log

# Production
dist/
build/

# Environment
# Only `.env` and `.env.example` are used. `.env` is local-only (real
# secrets / service URLs); `.env.example` is the committed template.
# Staging & prod read their values from Fly Secrets / CF Worker secrets,
# never from a committed file.
.env
.env.local
.env.*.local
.env.bak

# Defence-in-depth: catch ad-hoc secret files used to bootstrap Fly /
# Cloudflare environments (e.g. `fly secrets import < fly-*.env`).
*-secrets.env
*-secrets*.env
secrets.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Prisma
*.db
*.db-journal

# Prisma 7 - Generated Client
apps/api/src/generated/

# Storage (data directories at root, not source code)
/storage/
!/storage/.gitkeep
/uploads/
!/uploads/.gitkeep

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Temporary
*.tmp
tmp/
temp/

# Docker
# (No entries — .dockerignore is intentionally tracked so Fly's remote
# builder, GitHub Actions, and any local `docker build` all use the same
# build-context filtering.)

# Azure
.azure/
.azure-secrets-*.tmp
.azure-outputs-*.txt
.github-secrets-*.sh

# Next.js
.next/
out/
next-env.d.ts
*.tsbuildinfo

# Cloudflare / OpenNext build output and local state
.open-next/
.wrangler/

# Turborepo
.turbo/

# Uploaded files (disk storage)
uploads/
.vercel

# Files
*.localsettings.json
*.bicepparam
*.bicepstate
*.tar.gz
*.zip
*.pem
# Defence-in-depth: catch common typos / misnamed cert+key files
*.pem.txt
*.key
*.key.txt
*.crt
*.cer
*.pfx
*.p12
smart-apply-cert*
smart-apply-key*
cookies.txt